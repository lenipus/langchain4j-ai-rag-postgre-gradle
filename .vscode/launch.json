      "mainClass": "com.example.chat.Langchain4jRagApplication",
      "projectName": "langchain4j-ai-rag-postgre",
      "vmArgs": "-Dfile.encoding=UTF-8 -Dstdout.encoding=UTF-8 -Dstderr.encoding=UTF-8"
