      "env": {
        "SERVER_PORT": "8081",
        "POSTGRES_HOST": "localhost",
        "POSTGRES_PORT": "35432",
        "POSTGRES_USER": "tester",
        "POSTGRES_PASSWORD": "test123#",
        "EMBEDDING_MODEL_PATH": "/app/rag/onnx-uv/model", // 임베딩을 Ollama(embeddinggemma:300m)로 이전하면서 더 이상 사용 안 함
        "DOCUMENT_UPLOAD_PATH": "/app/rag/upload",
        "OLLAMA_BASE_URL": "http://localhost:31434"
      }
